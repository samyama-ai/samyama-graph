[0.002, "o", "  \u001b[2mcypher>\u001b[0m \u001b[33mMATCH \u001b[0m\u001b[1;33m(\u001b[0m\u001b[33mm:Model\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m-\u001b[0m\u001b[1;33m[\u001b[0m\u001b[33m:USES_FEATURE\u001b[0m\u001b[1;33m]\u001b[0m\u001b[33m->\u001b[0m\u001b[1;33m(\u001b[0m\u001b[1;33mf:Fea\u001b[0m\u001b[33mture\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m-\u001b[0m\u001b[1;33m[\u001b[0m\u001b[33m:DERIVED_FROM\u001b[0m\u001b[1;33m]\u001b[0m\u001b[33m->\u001b[0m\u001b[1;33m(\u001b[0m\u001b[33mds:DataSource\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m WHERE \u001b[0m\r\n\u001b[33mm.category = \u001b[0m\u001b[33m\"AML Transaction Monitoring\"\u001b[0m\u001b[33m RETURN m.name AS model, \u001b[0m\u001b[1;33mcollect\u001b[0m\u001b[1;33m(\u001b[0m\u001b[33mDISTINCT f.name\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m AS \u001b[0m\r\n\u001b[33mfeatures, \u001b[0m\u001b[1;33mcollect\u001b[0m\u001b[1;33m(\u001b[0m\u001b[33mDISTINCT ds.name\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m AS source_systems LIMIT \u001b[0m\u001b[1;33m5\u001b[0m\r\n"]
[0.008, "o", "\u001b[1;35mmodel                           \u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35mfeatures                        \u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35m \u001b[0m\u001b[1;35msource_systems                  \u001b[0m\r\nAML Transaction Monitoring · SME  ['debt_to_income',                ['Collateral Register', 'Credit \r\n#73                               'delinquency_30d_count',          Bureau Feed', 'Market Data      \r\n                                  'gdp_growth', 'hpi_change',       Feed', 'Payments Switch Log',   \r\n                                  'loan_to_value',                  'Treasury Positions']           \r\n                                  'rating_migration']                                               \r\nAML Transaction Monitoring ·      ['avg_balance_volatility',        ['Credit Bureau Feed', 'Deposits\r\nAuto #77                          'cash_intensity',                 Behavioural Store', 'KYC /      \r\n                                  'delinquency_30d_count',          Customer Master', 'Payments     \r\n                           "]
