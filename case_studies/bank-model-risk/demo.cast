[0.001, "o", "  \u001b[2mcypher>\u001b[0m \u001b[33mMATCH \u001b[0m\u001b[1;33m(\u001b[0m\u001b[33mm:Model\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m-\u001b[0m\u001b[1;33m[\u001b[0m\u001b[33m:VALIDATED_BY\u001b[0m\u001b[1;33m]\u001b[0m\u001b[33m->\u001b[0m\u001b[1;33m(\u001b[0m\u001b[33mv:Validation\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m-\u001b[0m\u001b[1;33m[\u001b[0m\u001b[33m:RAISED\u001b[0m\u001b[1;33m]\u001b[0m\u001b[33m->\u001b[0m\u001b[1;33m(\u001b[0m\u001b[33mf:ValidationFinding\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m WHERE \u001b[0m\r\n\u001b[33mm.tier = \u001b[0m\u001b[1;33m1\u001b[0m\u001b[33m AND m.status = \u001b[0m\u001b[33m\"Production\"\u001b[0m\u001b[33m AND f.severity = \u001b[0m\u001b[33m\"High\"\u001b[0m\u001b[33m AND f.status = \u001b[0m\u001b[33m\"Open\"\u001b[0m\u001b[33m RETURN m.name \u001b[0m\r\n\u001b[33mAS model, f.category AS finding_type, f.title AS finding, m.methodology AS method ORDER BY model \u001b[0m\r\n\u001b[33mLIMIT \u001b[0m\u001b[1;33m15\u001b[0m\r\n"]
