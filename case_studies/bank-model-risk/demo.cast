[0.000, "o", "  \u001b[2mcypher>\u001b[0m \u001b[33mMATCH \u001b[0m\u001b[1;33m(\u001b[0m\u001b[33mm:Model\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m-\u001b[0m\u001b[1;33m[\u001b[0m\u001b[33m:FEEDS*\u001b[0m\u001b[1;33m1\u001b[0m\u001b[33m..\u001b[0m\u001b[1;33m3\u001b[0m\u001b[1;33m]\u001b[0m\u001b[33m->\u001b[0m\u001b[1;33m(\u001b[0m\u001b[33ms:Submission\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m WHERE s.name = \u001b[0m\u001b[33m\"CCAR 2026\"\u001b[0m\u001b[33m RETURN m.category\u001b[0m\r\n\u001b[33mAS model_category, m.tier AS tier, \u001b[0m\u001b[1;33mcount\u001b[0m\u001b[1;33m(\u001b[0m\u001b[33mDISTINCT m\u001b[0m\u001b[1;33m)\u001b[0m\u001b[33m AS models ORDER BY models DESC\u001b[0m\r\n"]
